// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  STAFF
  DONOR
}

enum CampaignStatus {
  Draft
  Active
  Completed
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  passwordHash   String
  name           String
  phone          String?
  role           UserRole  @default(STAFF)
  isActive       Boolean   @default(true)
  organizationId Int?
  organization   Organization? @relation("OrganizationMembers", fields: [organizationId], references: [id])

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  createdOrganizations Organization[] @relation("OrganizationCreator")
  createdCampaigns     Campaign[]     @relation("CampaignCreator")
  createdDonors        Donor[]        @relation("DonorCreator")
  donationsRecorded    Donation[]     @relation("DonationRecordedBy")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([role])
  @@index([email])
}

model Organization {
  id           Int       @id @default(autoincrement())
  name         String
  slug         String    @unique
  email        String?
  phone        String?
  address      String?
  website      String?
  isActive     Boolean   @default(true)
  description  String?   
  logoUrl      String?  

  createdById  Int?
  createdBy    User?     @relation("OrganizationCreator", fields: [createdById], references: [id])

  users        User[]    @relation("OrganizationMembers")
  campaigns    Campaign[]
  donors       Donor[]
  donations    Donation[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([slug])
  @@index([isActive])
}

model RefreshToken {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Campaign {
  id              Int           @id @default(autoincrement())
  organizationId  Int
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title           String
  slug            String
  description     String?
  category        String?
  bannerImageUrl  String?
  status          CampaignStatus @default(Draft)
  goalAmount      Decimal       @db.Decimal(12, 2)
  currentAmount   Decimal       @db.Decimal(12, 2) @default(0)
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean       @default(true)

  createdById     Int?
  createdBy       User?         @relation("CampaignCreator", fields: [createdById], references: [id])

  donations       Donation[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([isActive])
  @@index([status])
  @@index([startDate, endDate])
}

model Donor {
  id              Int           @id @default(autoincrement())
  organizationId  Int
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  fullName        String
  email           String?
  phone           String?
  address         String?
  notes           String?
  isActive        Boolean       @default(true)

  createdById     Int?
  createdBy       User?         @relation("DonorCreator", fields: [createdById], references: [id])

  donations       Donation[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([email])
  @@index([isActive])
}

model Donation {
  id                Int           @id @default(autoincrement())
  organizationId    Int
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  campaignId        Int?
  campaign          Campaign?     @relation(fields: [campaignId], references: [id])

  donorId           Int?
  donor             Donor?        @relation(fields: [donorId], references: [id])

  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("PKR")
  paymentMethod     String?
  paymentReference  String?
  receiptNumber     String?       @unique
  notes             String?

  donatedAt         DateTime      @default(now())
  recordedById      Int?
  recordedBy        User?         @relation("DonationRecordedBy", fields: [recordedById], references: [id])

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([organizationId])
  @@index([campaignId])
  @@index([donorId])
  @@index([donatedAt])
}